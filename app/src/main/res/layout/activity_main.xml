<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0a0a0a">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sonne Caller"
        android:textSize="32sp"
        android:textColor="#22c55e"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Passerelle d'appel pour sonne.tel"
        android:textSize="14sp"
        android:textColor="#9ca3af"
        android:layout_marginBottom="48dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Service arrêté"
        android:textSize="18sp"
        android:textColor="#ffffff"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/startButton"
        android:layout_width="250dp"
        android:layout_height="56dp"
        android:text="Démarrer le service"
        android:textSize="16sp"
        android:backgroundTint="#22c55e"
        android:textColor="#ffffff"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/stopButton"
        android:layout_width="250dp"
        android:layout_height="56dp"
        android:text="Arrêter le service"
        android:textSize="16sp"
        android:backgroundTint="#ef4444"
        android:textColor="#ffffff"
        android:enabled="false" />

</LinearLayout>
